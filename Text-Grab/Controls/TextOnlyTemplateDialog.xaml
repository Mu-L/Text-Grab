<ui:FluentWindow
    x:Class="Text_Grab.Controls.TextOnlyTemplateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Text_Grab.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="New Text-Only Template"
    Width="520"
    Height="340"
    MinWidth="400"
    MinHeight="280"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Window.Resources>
        <ui:ImageIcon x:Key="TextGrabIcon" Source="/Text-Grab;component/Images/TealSelect40.png" />
    </Window.Resources>

    <Grid Background="{ui:ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            x:Name="TitleBarControl"
            Title="New Text-Only Template"
            Height="32"
            Margin="2,2,2,0"
            Padding="8,2"
            Icon="{StaticResource TextGrabIcon}" />

        <StackPanel Grid.Row="1" Margin="12">
            <TextBlock Margin="0,0,0,4" Text="Template Name:" />
            <TextBox
                x:Name="TemplateNameBox"
                Margin="0,0,0,12"
                TextChanged="ValidateInput" />

            <TextBlock Margin="0,0,0,4" Text="Output (type { to pick):" />
            <controls:InlinePickerRichTextBox
                x:Name="OutputTemplateBox"
                MinHeight="80"
                Margin="0,0,0,4"
                AcceptsReturn="True"
                AcceptsTab="True"
                TextChanged="OutputTemplateBox_TextChanged"
                ToolTip="Type { to insert a pattern placeholder. Plain text is also supported."
                VerticalScrollBarVisibility="Auto" />

            <TextBlock
                FontSize="11"
                Opacity="0.6"
                Text="Type { to pick from saved regex patterns. Use \n for newline."
                TextWrapping="Wrap" />

            <TextBlock
                x:Name="ErrorText"
                Margin="0,6,0,0"
                Foreground="Red"
                Text=""
                Visibility="Collapsed" />
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Margin="12,0,12,12"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                x:Name="SaveButton"
                Margin="0,0,6,0"
                Appearance="Primary"
                Click="SaveButton_Click"
                Content="Save"
                IsEnabled="False" />
            <ui:Button Click="CancelButton_Click" Content="Cancel" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
